# Copy to .env and edit:   cp .env.example .env
#
# docker compose reads this file automatically from the unified-app/ directory.

# --- Required ---

# Bearer token AIRI uses to authenticate against Hermes' OpenAI-compatible
# API server. Pick any long random string, e.g.:  openssl rand -hex 32
API_SERVER_KEY=

# --- Optional (defaults shown) ---

# Host port for the AIRI web frontend (http://localhost:6620)
#AIRI_PORT=6620

# Host port for the Hermes API server (http://localhost:8642/v1)
#HERMES_PORT=8642

# Browser origins allowed to call Hermes directly (CORS allowlist).
# Must include the origin you open AIRI from. Keep in sync with AIRI_PORT.
#API_SERVER_CORS_ORIGINS=http://localhost:6620,http://127.0.0.1:6620

# Model name Hermes advertises on /v1/models (what you'll pick in AIRI)
#API_SERVER_MODEL_NAME=hermes-agent

# Host UID/GID that should own the files Hermes writes under ./data/hermes.
# Set to your user so the data dir stays editable on the host:
#   HERMES_UID=$(id -u)  HERMES_GID=$(id -g)
#HERMES_UID=10000
#HERMES_GID=10000
